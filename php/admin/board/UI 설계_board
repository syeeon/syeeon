** 테이블 설계 **

인덱스    | idx        | int             | Ai, PK 
제목      | q_title    | varchar(100)    | nn
내용      | q_content  | text            | nn 
작성자    | writer     | varchar(15)     | nn 
비밀번호  | q_pwd      | varchar(20)      | nn 
작성일    | q_date     | date            | nn  
조회수    | cnt        | int             | default 0
done      | tinyint(1) | int             | default 0
 
//쿼리 작성

create table board(
    idx int auto_increment primary key,
    q_title varchar(100) not null,
    q_content text not null,
    answer text,
    writer varchar(15) not null,
    q_pwd varchar(20) not null,
    q_date date not null,
    cnt int default 0,
    done tinyint(1) default 0
);